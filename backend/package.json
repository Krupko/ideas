{
  "name": "@ideanick/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf ./dist && tsc --build ./tsconfig.json",
    "start": "tsx src/index.ts",
    "pmd": "prisma migrate dev",
    "pgc": "prisma generate",
    "pst": "prisma studio",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "lint": "pnpm exec eslint src --cache --cache-location ./node_modules/.cache/.eslintcache",
    "prettify": "prettier --log-level warn --cache --write '{*.ts,src/**/*.ts}' '!**/{node_modules,dist}/**/*'",
    "prepare": "pnpm pgc"
  },
  "prisma": {
    "schema": "./src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trpc/server": "^11.13.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lodash": "^4.17.23",
    "pg": "^8.20.0",
    "trpc-playground": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
