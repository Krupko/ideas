{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["./backend/src/*"],
      "@webapp/*": ["./webapp/src/*"]
    }
  },
  "include": ["backend/src/**/*", "webapp/src/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}
