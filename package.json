{
  "name": "ideanick",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "b": "pnpm --filter @ideanick/backend",
    "w": "pnpm --filter @ideanick/webapp",
    "lint": "concurrently 'pnpm run lint:b' 'pnpm run lint:w'",
    "lint:b": "pnpm --filter @ideanick/backend lint",
    "lint:w": "pnpm --filter @ideanick/webapp lint",
    "lint:staged:js": "eslint . --max-warnings=0",
    "lint:staged:css": "stylelint 'webapp/src/**/*.{css,scss}' --custom-syntax postcss-scss --max-warnings=0",
    "lint:staged:types": "tsc --noEmit --pretty",
    "types": "concurrently 'pnpm b types' 'pnpm w types'",
    "lint-fix": "stylelint \"webapp/src/**/*.{css,scss}\" --fix",
    "stylelint": "stylelint \"webapp/src/**/*.{css,scss}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
